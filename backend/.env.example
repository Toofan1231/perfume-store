
APP_NAME=Luxora Perfume API
ENVIRONMENT=development
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LOCAL_STORE_PATH=data/store.json
RATE_LIMIT_PER_MINUTE=120

# Turn this on only after Firebase Admin SDK credentials are configured.
USE_FIREBASE=false
FIREBASE_PROJECT_ID=luxora-perfume-store
FIREBASE_STORAGE_BUCKET=luxora-perfume-store.firebasestorage.app

# Option A: path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=

# Option B: full service account JSON as one environment variable
FIREBASE_SERVICE_ACCOUNT_JSON=
